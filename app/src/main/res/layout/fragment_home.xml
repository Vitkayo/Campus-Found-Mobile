<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_home_panel"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="10dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingHorizontal="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/app_name"
                        android:textColor="@color/primary"
                        android:textSize="@dimen/text_app_bar"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/darkModeButton"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_gravity="center_vertical|end"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/switch_to_dark_mode"
                    android:padding="@dimen/theme_toggle_padding"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_theme_dark" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingTop="2dp"
                android:paddingBottom="8dp">

                <TextView
                    android:id="@+id/lostCountText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_home_chip_lost"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:textColor="@color/status_lost_text"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/foundCountText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_home_chip_found"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:textColor="@color/status_found_text"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/totalCountText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_home_chip_total"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:textColor="@color/home_chip_total_text"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/searchLayout"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginHorizontal="16dp"
                android:background="@drawable/bg_home_search"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="13dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_search_24" />

                <EditText
                    android:id="@+id/searchInput"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="@string/search_hint"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:padding="0dp"
                    android:singleLine="true"
                    android:textColor="@color/on_surface"
                    android:textColorHint="@color/outline"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/filterRow"
                android:layout_width="match_parent"
                android:layout_height="@dimen/home_filter_height"
                android:layout_marginTop="10dp"
                android:baselineAligned="false"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView
                    android:id="@+id/filterAllButton"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_home_filter_chip"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:minWidth="52dp"
                    android:paddingHorizontal="12dp"
                    android:tag="filter_chip_All"
                    android:text="@string/filter_all"
                    android:textColor="@color/home_filter_chip_text"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/filterLostButton"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_home_filter_chip"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:minWidth="52dp"
                    android:paddingHorizontal="12dp"
                    android:tag="filter_chip_Lost"
                    android:text="@string/filter_lost"
                    android:textColor="@color/home_filter_chip_text"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/filterFoundButton"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_home_filter_chip"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:minWidth="52dp"
                    android:paddingHorizontal="12dp"
                    android:tag="filter_chip_Found"
                    android:text="@string/filter_found"
                    android:textColor="@color/home_filter_chip_text"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <AutoCompleteTextView
                    android:id="@+id/categoryFilterInput"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_home_filter_dropdown"
                    android:clickable="true"
                    android:contentDescription="@string/category"
                    android:drawableEnd="@drawable/ic_arrow_drop_down_16"
                    android:drawablePadding="4dp"
                    android:dropDownVerticalOffset="4dp"
                    android:ellipsize="end"
                    android:focusable="false"
                    android:gravity="center_vertical"
                    android:inputType="none"
                    android:maxLines="1"
                    android:paddingStart="12dp"
                    android:paddingEnd="8dp"
                    android:popupBackground="@color/surface_container_high"
                    android:singleLine="true"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_sparkle_16" />

                <TextView
                    android:id="@+id/resultsCountText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="@color/outline"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/itemsRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="24dp" />

                <ProgressBar
                    android:id="@+id/loadingProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/emptyStateLayout"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="32dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/empty_items"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/errorStateLayout"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="32dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/errorMessageText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/error_loading"
                        android:textColor="@color/error"
                        android:textSize="@dimen/text_body" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/retryButton"
                        style="@style/Widget.CampusFound.Button.Outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/retry" />
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
