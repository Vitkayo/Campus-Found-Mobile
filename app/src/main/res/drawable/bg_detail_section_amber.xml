<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <solid android:color="@color/surface_container_low" />
            <corners android:radius="12dp" />
            <stroke android:width="1dp" android:color="@color/outline_variant" />
        </shape>
    </item>
    <item android:gravity="start">
        <shape>
            <size android:width="3dp" />
            <solid android:color="@color/accent_photo" />
            <corners android:topLeftRadius="12dp" android:bottomLeftRadius="12dp" />
        </shape>
    </item>
</layer-list>
